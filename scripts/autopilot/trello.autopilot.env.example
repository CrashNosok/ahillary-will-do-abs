# Copy to `trello.autopilot.env` (gitignored) and fill in your Trello credentials.
# The script reads this file automatically (DEFAULT_CREDS_FILE). Board/list/port defaults
# are baked into the script's DEFAULTS for the "ahillary-will-do-abs MVP" board — you only
# need to set credentials below. Override anything else by uncommenting it.

TRELLO_API_KEY=
TRELLO_TOKEN=

# --- Optional overrides (else built-in defaults apply) ---
# TRELLO_BOARD_ID=O1qQWGbJ
# TRELLO_BOARD_NAME=ahillary-will-do-abs MVP
# TRELLO_SOURCE_LISTS=📋 Backlog,🟡 To Do
# TRELLO_DOING_LIST=🔵 In Progress
# TRELLO_REVIEW_LIST=🟣 Code Review
# TRELLO_BLOCKED_LIST=🟠 Blocked
# TRELLO_PICKUP_LABEL=
# WEB_BASE_URL=http://localhost:5173
# API_HEALTH_URL=http://localhost:8000/health
# CLAUDE_MODEL=opus
# CLAUDE_MAX_TURNS=300
# TASK_TIMEOUT_SECONDS=5400
