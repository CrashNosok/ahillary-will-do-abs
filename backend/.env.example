# Скопируй в backend/.env и заполни значения. backend/.env в .gitignore — секреты не коммитим.
# Конфиг читается через pydantic-settings (см. карточку S0.3).

# --- LLM через OpenRouter (OpenAI-совместимый; модель выбирается через MODEL_*) ---
# Ключ возьми на https://openrouter.ai/keys (формат sk-or-v1-...).
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Любая модель OpenRouter (слаги: https://openrouter.ai/models), например:
# anthropic/claude-sonnet-4.6, anthropic/claude-opus-4.8, openai/gpt-4o, google/gemini-2.5-flash.
# MODEL_VISION должна поддерживать картинки (распознавание скрина).
MODEL_VISION=anthropic/claude-sonnet-4.6
MODEL_RECO=anthropic/claude-opus-4.8

# --- Сессии (подпись cookie) ---
SECRET_KEY=change-me-to-a-long-random-string

# --- Единственный сид-аккаунт (регистрации нет) ---
SEED_USER_EMAIL=me@example.com
SEED_USER_PASSWORD=change-me
